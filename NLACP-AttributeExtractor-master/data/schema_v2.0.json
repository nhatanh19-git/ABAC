{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ABAC Policy Schema v2.0",
  "description": "Schema for structured extraction of Access Control Policies from natural language sentences",
  "type": "object",
  "required": ["version", "domain", "policies"],
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version"
    },
    "domain": {
      "type": "string",
      "description": "Domain name (e.g., 'university', 'healthcare', 'banking')"
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Policy"
      }
    }
  },
  "definitions": {
    "Policy": {
      "type": "object",
      "required": ["id", "sentence", "authorization_decision", "policy_modality", "subjects", "actions", "resource", "environments", "context"],
      "properties": {
        "id": {
          "type": "integer",
          "description": "Policy unique identifier"
        },
        "sentence": {
          "type": "string",
          "description": "Original ACP sentence in natural language"
        },
        "authorization_decision": {
          "type": "string",
          "enum": ["permit", "deny"],
          "description": "Authorization decision: permit or deny"
        },
        "policy_modality": {
          "type": "string",
          "enum": ["can", "cannot", "must", "only_if", "only_allowed"],
          "description": "Modal verb or phrase indicating policy modality"
        },
        "priority": {
          "type": "integer",
          "description": "Policy priority (optional)"
        },
        "subjects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/Subject"
          },
          "description": "Array of subject entities"
        },
        "subjects_logical_op": {
          "type": "string",
          "enum": ["AND", "OR"],
          "description": "Logical operator between multiple subjects (if applicable)"
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/Action"
          },
          "description": "Array of actions/operations"
        },
        "actions_logical_op": {
          "type": "string",
          "enum": ["AND", "OR"],
          "description": "Logical operator between multiple actions (if applicable)"
        },
        "resource": {
          "$ref": "#/definitions/Resource",
          "description": "Resource/object being accessed"
        },
        "environments": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Environment"
          },
          "description": "Environmental constraints (system, temporal, location, network)"
        },
        "context": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Condition"
          },
          "description": "Array of policy context/conditions"
        },
        "conditions_logical_op": {
          "type": "string",
          "enum": ["AND", "OR"],
          "description": "Logical operator between multiple conditions (if applicable)"
        },
        "relation_pairs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RelationPair"
          },
          "description": "Relationships between policy components"
        },
        "abac_policy": {
          "type": "string",
          "description": "One-line ABAC policy summary"
        }
      }
    },
    "Subject": {
      "type": "object",
      "required": ["entity_type"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["user", "role", "group", "system", "agreement", "schedule"],
          "description": "Type of subject entity"
        },
        "ref_tokens": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tokens from the sentence referencing this subject"
        },
        "role": {
          "type": "string",
          "description": "Normalized role name (e.g., 'student', 'lecturer', 'coordinator')"
        },
        "qualifiers": {
          "$ref": "#/definitions/SubjectQualifier"
        },
        "namespace": {
          "type": "string",
          "description": "Subject namespace (e.g., 'subject.user.student.civilian')"
        }
      }
    },
    "SubjectQualifier": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["civilian", "visiting", "retired", "official", null],
          "description": "Subject type qualifier"
        },
        "rank": {
          "type": "string",
          "enum": ["senior", "head", "chair", "coordinator", null],
          "description": "Subject rank qualifier"
        },
        "status": {
          "type": "string",
          "enum": ["retired", "active", "not_yet_retired", null],
          "description": "Subject status qualifier"
        },
        "office": {
          "type": ["string", "array"],
          "description": "Office or department (e.g., 'academic_affairs', 'examination')"
        },
        "department": {
          "type": "string",
          "enum": ["own", "any", null],
          "description": "Department scope qualifier"
        },
        "negated": {
          "type": "boolean",
          "description": "True if subject is negated (e.g., 'who are NOT')"
        }
      }
    },
    "Action": {
      "type": "object",
      "required": ["verb", "operation"],
      "properties": {
        "verb": {
          "type": "string",
          "description": "Original verb from the sentence"
        },
        "operation": {
          "type": "string",
          "enum": [
            "CREATE", "READ", "UPDATE", "DELETE", "UPLOAD", "DOWNLOAD",
            "COMMENT", "APPROVE", "DENY", "ASSIGN", "ASSESS", "EXPORT",
            "NUMBER", "ISSUE", "REGISTER", "CANCEL", "CHECK", "TAKE",
            "EXECUTE", "REQUIRE", "TRANSFER"
          ],
          "description": "Normalized operation type"
        },
        "negated": {
          "type": "boolean",
          "description": "True if action is negated"
        }
      }
    },
    "Resource": {
      "type": "object",
      "required": ["entity_type"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["data", "document", "record", "schedule", "agreement", "offering", "registration", "attribute"],
          "description": "Type of resource"
        },
        "ref_tokens": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tokens from the sentence referencing this resource"
        },
        "label": {
          "type": "string",
          "description": "Normalized resource label (snake_case, e.g., 'student_score')"
        },
        "qualifier": {
          "type": "string",
          "enum": ["own", "every", "all", "the", "entire", null],
          "description": "Resource qualifier"
        },
        "scope": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": ["self", "course", "department", "all", "external", "none"],
              "description": "Scope level"
            },
            "ref": {
              "type": "string",
              "enum": ["enrolled_courses", "that_course", "own_department", "that_department", "per_year", "all", "self"],
              "description": "Scope reference"
            }
          },
          "description": "Resource scope definition"
        },
        "subject_filter": {
          "type": ["string", "null"],
          "description": "Type of subject owning this resource (e.g., 'civilian_student')"
        },
        "attributes": {
          "type": "object",
          "properties": {
            "sensitivity": {
              "type": "string",
              "enum": ["public", "internal", "confidential", "secret"],
              "description": "Data sensitivity level"
            },
            "status": {
              "type": "string",
              "enum": ["open", "closed", "submitted", "issued", "numbered", "official", "approved", null],
              "description": "Resource status"
            }
          },
          "description": "Resource attributes"
        },
        "namespace": {
          "type": "string",
          "description": "Resource namespace (e.g., 'resource.data.student_score')"
        }
      }
    },
    "Environment": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Environment identifier (e.g., 'env_1')"
        },
        "env_type": {
          "type": "string",
          "enum": ["system", "temporal", "location", "network"],
          "description": "Type of environment constraint"
        },
        "trigger_phrase": {
          "type": "string",
          "description": "Original phrase from sentence triggering this environment"
        },
        "trigger_word": {
          "type": "string",
          "enum": ["in", "at", "between", "after", "before"],
          "description": "Trigger preposition"
        },
        "systems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "System name (snake_case)"
              },
              "namespace": {
                "type": "string",
                "enum": ["env.system.ais", "env.system.lms", "env.system.vlms", "env.system.crs"],
                "description": "System namespace"
              }
            }
          },
          "description": "List of systems involved"
        },
        "time_range": {
          "type": "object",
          "properties": {
            "from": {
              "type": "string",
              "pattern": "^([0-1][0-9]|2[0-3]):[0-5][0-9]$",
              "description": "Start time (HH:MM format)"
            },
            "to": {
              "type": "string",
              "pattern": "^([0-1][0-9]|2[0-3]):[0-5][0-9]$",
              "description": "End time (HH:MM format)"
            }
          },
          "description": "Temporal range (if applicable)"
        }
      }
    },
    "Condition": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Condition identifier (e.g., 'cond_1')"
        },
        "type": {
          "type": "string",
          "enum": [
            "relational", "temporal", "status", "threshold", "approval",
            "prerequisite", "membership", "overlap", "system_state", "obligation"
          ],
          "description": "Condition type"
        },
        "trigger_phrase": {
          "type": "string",
          "description": "Original phrase from sentence triggering this condition"
        },
        "left_operand": {
          "type": "string",
          "description": "Left side of condition (attribute path, e.g., 'subject.role' or 'resource.status')"
        },
        "operator": {
          "type": "string",
          "enum": ["eq", "neq", "in", "not_in", "lt", "lte", "gt", "gte", "contains", "overlaps", "has_not_passed"],
          "description": "Comparison operator"
        },
        "right_operand": {
          "type": ["string", "null"],
          "description": "Right side if comparing two attributes (null if using value)"
        },
        "value": {
          "type": ["string", "number", "boolean", "null"],
          "description": "Literal value if not comparing attributes"
        },
        "value_unit": {
          "type": "string",
          "enum": ["hours", "hours/year", "credits", "students", "vnd", null],
          "description": "Unit of measurement for value"
        },
        "approver_entity": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "description": "List of approver entities (for approval conditions)"
        },
        "approval_state": {
          "type": "string",
          "enum": ["approved", "rejected", null],
          "description": "Expected approval state (for approval conditions)"
        },
        "formal_expression": {
          "type": "string",
          "description": "Formal boolean expression (e.g., 'resource.score > 5')"
        },
        "negated": {
          "type": "boolean",
          "description": "True if condition is negated"
        }
      }
    },
    "RelationPair": {
      "type": "object",
      "properties": {
        "entity": {
          "type": "string",
          "enum": ["subject", "resource", "action"],
          "description": "Entity type"
        },
        "rel_type": {
          "type": "string",
          "enum": ["attribute", "possession", "scope", "membership", "quantity", "status"],
          "description": "Relation type"
        },
        "attribute": {
          "type": "string",
          "description": "Attribute name"
        },
        "value": {
          "type": ["string", "number"],
          "description": "Attribute value"
        }
      }
    }
  }
}
